# Vercel Postgres — these are added automatically when you connect a Postgres database in Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Auth — generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=https://your-app.vercel.app

# The password you'll use to log in
ADMIN_PASSWORD=choose-a-strong-password
